# ─── Database (PostgreSQL) ───────────────────────────────
# Format: postgresql+psycopg2://USER:PASSWORD@HOST/DB_NAME
DATABASE_URL="postgresql+psycopg2://postgres:yourpassword@localhost/local_marketplace"

# ─── App ─────────────────────────────────────────────────
SECRET_KEY="change-this-to-a-random-64-char-string"
ENVIRONMENT="development"

# ─── CORS (frontend URL) ─────────────────────────────────
CORS_ORIGINS="http://localhost:5173"

# ─── Email (Gmail SMTP) ──────────────────────────────────
# Step 1: Gmail mein 2-Step Verification ON karo
# Step 2: https://myaccount.google.com/apppasswords par jaao
# Step 3: "Mail" -> "Windows Computer" -> Generate -> 16 char password copy karo
MAIL_FROM="yourname@gmail.com"
MAIL_PASSWORD="xxxx xxxx xxxx xxxx"
MAIL_ADMIN="admin@yourdomain.com"

# ─── Cloudinary (product images) ─────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
